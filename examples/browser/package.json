{
  "name": "bashkit-browser-example",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "start": "pnpm run build:wasm && vite",
    "build:wasm": "cd ../../crates/bashkit-js && pnpm run build:wasm",
    "dev": "vite",
    "build": "pnpm run build:wasm && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "@everruns/bashkit": "file:../../crates/bashkit-js",
    "@napi-rs/wasm-runtime": "^1.1.1"
  },
  "devDependencies": {
    "vite": "^6.4.3"
  },
  "pnpm": {
    "overrides": {
      "esbuild": ">=0.28.1"
    },
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
